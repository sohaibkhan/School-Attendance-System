# App
PORT=3000
SESSION_SECRET=change_this_to_a_long_random_secret

# MySQL / Aiven
DB_HOST=dbhost
DB_PORT=3306
DB_USER=user
DB_PASSWORD=DBPASS
DB_NAME=defaultdb

# Aiven requires SSL. For quick local development this keeps SSL enabled.
# For production, use the Aiven CA certificate and set DB_SSL_REJECT_UNAUTHORIZED=true.
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
