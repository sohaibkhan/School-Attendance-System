<%- include('../layouts/header', { title: 'Admin Dashboard' }) %>
<%- include('../layouts/sidebar') %>

<h2 class="mb-4">Admin Dashboard</h2>
<div class="row g-3">
  <div class="col-md-4 col-xl">
    <div class="card card-summary"><div class="card-body"><div class="text-muted">Total Teachers</div><h3><%= counts.teachers %></h3></div></div>
  </div>
  <div class="col-md-4 col-xl">
    <div class="card card-summary"><div class="card-body"><div class="text-muted">Total Students</div><h3><%= counts.students %></h3></div></div>
  </div>
  <div class="col-md-4 col-xl">
    <div class="card card-summary"><div class="card-body"><div class="text-muted">Total Parents</div><h3><%= counts.parents %></h3></div></div>
  </div>
  <div class="col-md-4 col-xl">
    <div class="card card-summary"><div class="card-body"><div class="text-muted">Total Classes</div><h3><%= counts.classes %></h3></div></div>
  </div>
  <div class="col-md-4 col-xl">
    <div class="card card-summary"><div class="card-body"><div class="text-muted">Attendance Records</div><h3><%= counts.attendance %></h3></div></div>
  </div>
</div>

<div class="card mt-4">
  <div class="card-body">
    <h5>System Purpose</h5>
    <p class="mb-0">Teachers can mark attendance. When a student is marked absent, the system creates an in-app notification for the linked parent.</p>
  </div>
</div>

<%- include('../layouts/footer') %>
