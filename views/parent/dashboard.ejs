<%- include('../layouts/header', { title: 'Parent Dashboard' }) %>
<%- include('../layouts/sidebar') %>

<h2 class="mb-4">Parent Dashboard</h2>
<div class="row g-3">
  <div class="col-md-6">
    <div class="card card-summary"><div class="card-body"><div class="text-muted">Linked Children</div><h3><%= children.length %></h3></div></div>
  </div>
  <div class="col-md-6">
    <div class="card card-summary"><div class="card-body"><div class="text-muted">Unread Notifications</div><h3><span class="badge bg-danger"><%= unreadCount %></span></h3></div></div>
  </div>
</div>

<div class="row g-3 mt-2">
  <div class="col-lg-6">
    <div class="card h-100">
      <div class="card-header">My Children</div>
      <div class="card-body table-responsive">
        <table class="table table-striped">
          <thead><tr><th>Name</th><th>Roll</th><th>Class</th><th>Status</th></tr></thead>
          <tbody>
            <% children.forEach((child) => { %>
              <tr>
                <td><%= child.name %></td>
                <td><%= child.roll_number %></td>
                <td><%= child.class_name %> - <%= child.section %></td>
                <td><span class="badge <%= child.status === 'active' ? 'bg-success' : 'bg-secondary' %>"><%= child.status %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="card h-100">
      <div class="card-header">Recent Notifications</div>
      <div class="card-body">
        <% recentNotifications.forEach((notification) => { %>
          <div class="border-bottom py-2">
            <strong><%= notification.title %></strong>
            <span class="badge <%= notification.is_read ? 'bg-secondary' : 'bg-danger' %>"><%= notification.is_read ? 'Read' : 'Unread' %></span>
            <p class="mb-0 small"><%= notification.message %></p>
          </div>
        <% }) %>
        <% if (recentNotifications.length === 0) { %><p class="text-muted mb-0">No notifications yet.</p><% } %>
      </div>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>
