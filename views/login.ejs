<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Smart School Attendance</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="login-page">
  <div class="container">
    <div class="row justify-content-center align-items-center min-vh-100">
      <div class="col-md-5 col-lg-4">
        <div class="card shadow border-0">
          <div class="card-body p-4">
            <h3 class="text-center mb-1">Smart School Attendance</h3>
            <p class="text-center text-muted mb-4">Login to your portal</p>

            <% if (error) { %>
              <div class="alert alert-danger"><%= error %></div>
            <% } %>
            <% if (success) { %>
              <div class="alert alert-success"><%= success %></div>
            <% } %>

            <form action="/login" method="POST">
              <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" placeholder="admin@school.com" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control" placeholder="password" required>
              </div>
              <button type="submit" class="btn btn-primary w-100">Login</button>
            </form>

            <div class="demo-box mt-4 small">
              <strong>Demo Users</strong><br>
              Admin: admin@school.com / password<br>
              Teacher: teacher@school.com / password<br>
              Parent: parent@school.com / password
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
