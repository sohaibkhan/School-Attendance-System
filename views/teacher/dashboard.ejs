<%- include('../layouts/header', { title: 'Teacher Dashboard' }) %>
<%- include('../layouts/sidebar') %>

<h2 class="mb-4">Teacher Dashboard</h2>
<div class="row g-3">
  <div class="col-md-3"><div class="card card-summary"><div class="card-body"><div class="text-muted">Assigned Classes</div><h3><%= counts.classes %></h3></div></div></div>
  <div class="col-md-3"><div class="card card-summary"><div class="card-body"><div class="text-muted">Students</div><h3><%= counts.students %></h3></div></div></div>
  <div class="col-md-3"><div class="card card-summary"><div class="card-body"><div class="text-muted">Attendance Records</div><h3><%= counts.attendance %></h3></div></div></div>
  <div class="col-md-3"><div class="card card-summary"><div class="card-body"><div class="text-muted">Absent Records</div><h3><%= counts.absent %></h3></div></div></div>
</div>

<div class="card mt-4">
  <div class="card-body">
    <h5>Next Step</h5>
    <p>Select your assigned class and date to mark attendance.</p>
    <a href="/teacher/attendance" class="btn btn-primary">Take Attendance</a>
  </div>
</div>

<%- include('../layouts/footer') %>
