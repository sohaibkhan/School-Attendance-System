<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Smart School Attendance' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
  <div class="container-fluid">
    <a class="navbar-brand fw-bold" href="/">Smart School Attendance</a>
    <% if (user) { %>
      <div class="d-flex align-items-center gap-3 text-white">
        <span class="small">Logged in as <strong><%= user.name %></strong> (<%= user.role %>)</span>
        <form action="/logout" method="POST" class="m-0">
          <button class="btn btn-sm btn-light" type="submit">Logout</button>
        </form>
      </div>
    <% } %>
  </div>
</nav>

<div class="container-fluid">
  <div class="row">
